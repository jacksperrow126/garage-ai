# Copy to .env for local dev. Production values come from Cloud Run env vars
# backed by Secret Manager — never commit real secrets.

# Firebase / GCP
GOOGLE_CLOUD_PROJECT=garage-ai
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Emulator wiring for local dev (unset in production)
FIRESTORE_EMULATOR_HOST=localhost:8080
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099

# API key OpenClaw uses to call REST + MCP tools
OPENCLAW_API_KEY=change-me-locally

# CORS origins for the admin panel (comma-separated)
ADMIN_ORIGINS=http://localhost:3000

# Environment label ("local" | "staging" | "prod")
APP_ENV=local
