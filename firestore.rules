rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────
// All client reads/writes go through our FastAPI backend, which uses the
// Firebase Admin SDK (bypasses these rules). Direct client access is denied.
// This removes a whole class of data-integrity bugs: there is literally no
// way for the admin panel or a compromised client to mutate Firestore
// outside the service-layer transactions.
// ─────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
